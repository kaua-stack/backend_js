{
  "openapi": "3.0.0",
  "info": {
    "title": "My API",
    "version": "1.0.0",
    "description": "API documentation for my application"
  },
  "servers": [
    {
      "url": "http://localhost:6050",
      "description": "Local server"
    }],

  "paths": {
    "/auth/login": {
      "post": {
        "summary": "User login",
        "description": "Realiza o login",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Login"
              },
              "example": {
                "user_email": "email@email",
                "user_password": "123456"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful login"
          },
          "400": {
            "description": "Invalid request body"
          },
          "401": {
            "description": "Invalid credentials"
          },
          "404": {
            "description": "User not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },

    "/auth/refresh": {
      "post": {
        "summary": "Refresh token do usuario",
        "description": "Realiza o refresh do token do usuario",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshToken"
              },"token": {
              "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VyX2lkIjoxMjM0NTY3ODkwLCJleHAiOjE2MzQyMzQwMDB9.abc123"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful login"
          },
          "400": {
            "description": "Invalid request body"
          },
          "401": {
            "description": "Invalid credentials"
          },
          "404": {
            "description": "User not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },

    "/auth/logout": {
      "post": {
        "summary": "Logout do usuario",
        "description": "Realiza o logout do usuario",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/logout"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful logout"
          },
          "400": {
            "description": "Invalid request body"
          },
          "401": {
            "description": "Invalid credentials"
          },
          "404": {
            "description": "User not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },

    "/users": {
      "get": {
        "summary": "buscar todos usuarios",
        "description": "Retorna todos os usuarios",
        "tags": [
          "Users"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Users"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    }

  },

  "components": {
    "schemas": {
      "Login": {
        "type": "object",
        "properties": {
          "user_email": {
            "type": "string",
            "description": "email do usuario",
            "example": "email@email"
          },
          "user_password": {
            "type": "string"
          }
        }
      },

      "RefreshToken": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          }
        }
      },

      "logout": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          }
        }
      },

      "Users": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "integer"
          },
          "user_name": {
            "type": "string"
          },
          "user_email": {
            "type": "string"
          }
        }
      }
    },
    
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}