{
  "openapi": "3.0.0",
  "info": {
    "title": "API Livraria",
    "version": "1.0.0",
    "description": "API para gerenciamento de uma livraria, incluindo clientes, categorias, compras, produtos, usuários e autenticação."
  },
  "servers": [
    {
      "url": "http://localhost:6050",
      "description": "Servidor local"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Login de usuário",
        "description": "Autentica usuário e retorna um token JWT.",
        "tags": [
          "Autenticação"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/login"
              },
              "example": {
                "user_email": "exemplo@dominio.com",
                "user_password": "senha123@S"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login bem-sucedido",
            "headers": {
              "Set-Cookie": {
                "description": "Token JWT para autenticação",
                "schema": {
                  "type": "string",
                  "example": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                }
              }
            }
          },
          "401": {
            "description": "Credenciais inválidas"
          },
          "404": {
            "description": "Usuário não encontrado"
          },
          "500": {
            "description": "Erro interno do servidor"
          }
        }
      }
    },


    "/auth/refresh": {
  "post": {
    "summary": "Refresh token de acesso",
    "description": "Atualiza o token de acesso usando o token de refresh.",
    "tags": [
      "Autenticação"
    ],
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "required": ["token"],
            "properties": {
              "token": {
                "type": "string",
                "description": "Token de refresh",
                "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9"
              }
            }
          }
        }
      }
    },
    "responses": {
      "200": {
        "description": "Token atualizado com sucesso",
        "headers": {
          "Set-Cookie": {
            "description": "Novo token JWT armazenado em cookie",
            "schema": {
              "type": "string",
              "example": "accessToken=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9"
            }
          }
        }
      },
      "400": {
        "description": "Token de refresh não informado ou requisição inválida"
      },
      "401": {
        "description": "Token de refresh inválido ou expirado"
      },
      "500": {
        "description": "Erro interno do servidor"
      }
    }
  }
    },


    "/auth/logout": {
  "post": {
    "summary": "Logout de usuário",
    "description": "Encerra a sessão do usuário e invalida o token JWT.",
    "tags": [
      "Autenticação"
    ],
    "responses": {
      "200": {
        "description": "Logout bem-sucedido"
      },
      "401": {
        "description": "Usuário não autenticado"
      },
      "500": {
        "description": "Erro interno do servidor"
      }
    }
  }
    }








  },
  "components": {
    "schemas": {
      "login": {
        "type": "object",
        "properties": {
          "user_email": {
            "type": "string",
            "description": "Email do usuário"
          },
          "user_password": {
            "type": "string"
          }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
